# --- 1. CONFIGURATION BASE DE DONNEES (PostgreSQL) ---
# Ce sont les infos utilisées par le conteneur "db" pour se créer
POSTGRES_USER=theobessel
POSTGRES_PASSWORD=root
POSTGRES_DB=grinp

# --- 2. CONFIGURATION APPLICATION WEB ---
# L'URL interne pour que le site parle à la base (host = "db")
DATABASE_URL=postgresql://theobessel:root@db:5432/grinp

# --- 3. ADRESSES DU SITE (CHOISIS UNE OPTION) ---

# OPTION A : Si tu utilises le nom de domaine (Recommandé)
ORIGIN=https://grinp.inpt.fr
REDIRECT_URI=https://grinp.inpt.fr/login

# OPTION B : Si tu utilises l'IP (Si le domaine ne marche pas encore)
# (Enlève les # devant les 2 lignes ci-dessous et mets des # devant l'Option A)
# ORIGIN=http://4.233.209.231
# REDIRECT_URI=http://4.233.209.231/login

# --- 4. SECURITE & PRODUCTION ---
# Important : Passe DEV à false pour que le site soit rapide et sécurisé
DEV=false

# Port interne (ne touche pas, c'est mappé sur le 80 via docker-compose)
PORT=3000

